// Earendel Prisma schema — full relational schema.
// For production: change provider to "postgresql" and update DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ Auth (NextAuth) ============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  role          String    @default("member")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  connectors    Connector[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ Core Domain ============

/// An authorised bridge to a target app/portal.
model Connector {
  id            String   @id @default(cuid())
  name          String
  targetApp     String
  targetDomain  String
  workflow      String
  category      String   @default("other")
  permission    String   @default("read_only")
  riskLevel     String   @default("low")
  allowedDomains String   @default("[]")
  authMethod    String   @default("password")
  status        String   @default("active")
  credentialVaultKey String @default("")
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User?     @relation(fields: [userId], references: [id])
  actions       TypedAction[]
  recordings    Recording[]

  @@index([userId])
  @@index([category])
  @@index([status])
}

/// A compiled, versioned, risk-gated typed action.
model TypedAction {
  id              String   @id @default(cuid())
  connectorId     String
  name            String
  signature       String
  description     String
  category        String   @default("other")
  contract        String   @default("{}")
  permissions     String   @default("read_only")
  riskLevel       String   @default("low")
  executionMethods String  @default("[]")
  preferredAdapter String  @default("api")
  status          String   @default("draft")
  version         String   @default("0.1.0")
  versions        String   @default("[]")
  testsPassed     Int      @default(0)
  testsTotal      Int      @default(0)
  canary          String   @default("[]")
  publishedAs     String   @default("[]")
  mcpToolName     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  connector       Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  executions      Execution[]
  repairs         RepairProposal[]

  @@index([connectorId])
  @@index([status])
  @@index([category])
}

/// A captured workflow recording (before compilation).
model Recording {
  id              String   @id @default(cuid())
  connectorId     String
  name            String
  steps           String   @default("[]")
  totalDurationMs Int      @default(0)
  networkRequests Int      @default(0)
  domMutations    Int      @default(0)
  screenshots     Int      @default(0)
  harCaptured     Boolean  @default(true)
  har             String   @default("{}")
  cookies         String   @default("{}")
  status          String   @default("captured")
  compiledActionId String?
  createdAt       DateTime @default(now())

  connector       Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId])
  @@index([status])
}

/// An execution of a typed action through the multi-adapter chain.
model Execution {
  id              String   @id @default(cuid())
  actionId        String
  actionName      String
  caller          String   @default("manual")
  inputs          String   @default("{}")
  outputs         String?
  adapter         String   @default("api")
  fallbackChain   String   @default("[]")
  status          String   @default("queued")
  durationMs      Int      @default(0)
  traces          String   @default("[]")
  screenshots     String   @default("[]")
  postconditionsMet Boolean?
  errorMessage    String?
  riskApproved    Boolean  @default(true)
  startedAt       DateTime @default(now())
  finishedAt      DateTime?

  action          TypedAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([actionId])
  @@index([status])
  @@index([startedAt])
}

/// A repair proposal for a failed selector.
model RepairProposal {
  id              String   @id @default(cuid())
  actionId        String
  actionVersion   String
  failedSelector  String
  candidateSelector String
  candidateLabel  String
  confidence      Float    @default(0.8)
  reason          String
  status          String   @default("pending")
  detectedAt      DateTime @default(now())
  source          String   @default("fallback")
  patternKey      String?

  action          TypedAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([actionId])
  @@index([status])
}

/// Human review queue (for high-risk actions).
model Review {
  id              String   @id @default(cuid())
  actionId        String
  actionName      String
  actionVersion   String
  caller          String
  inputs          String   @default("{}")
  prompt          String
  expectedOutputs String   @default("[]")
  status          String   @default("pending")
  reviewedBy      String?
  reviewedAt      DateTime?
  outputs         String?
  rejectReason    String?
  createdAt       DateTime @default(now())

  @@index([actionId])
  @@index([status])
}

// ============ Network Discovery (Option B — the technical moat) ============

/// A network endpoint discovered from HAR capture during recording.
/// Replayed by the internal_route adapter instead of clicking through the browser.
/// 10x faster + 10x more reliable than browser automation (per APISENSOR research).
model DiscoveredEndpoint {
  id              String   @id @default(cuid())
  actionName      String
  connectorId     String?
  method          String   @default("POST")
  url             String
  urlPattern      String   @default("")
  bodyTemplate    String   @default("{}")
  headersTemplate String   @default("{}")
  cookieEnvVar    String   @default("")
  fieldMapping    String   @default("{}")
  responseShape   String   @default("{}")
  businessScore   Float    @default(0.0)
  clusterSize     Int      @default(1)
  status          String   @default("active")
  staleReason     String?
  timesReplayed   Int      @default(0)
  timesSucceeded  Int      @default(0)
  timesFailed     Int      @default(0)
  avgLatencyMs    Int      @default(0)
  discoveredFrom  String   @default("har")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastReplayedAt  DateTime?

  @@index([actionName])
  @@index([status])
  @@index([connectorId])
}

// ============ Repair Flywheel (Option A — the defensive moat) ============

/// Cross-client repair knowledge base entry.
/// When a repair is approved (LLM or human), it is stored here so that the
/// NEXT client hitting the same portal + widget pattern gets an instant repair.
/// This is the network-effect flywheel: every rupture repaired makes the next
/// one faster for everyone.
model RepairKnowledge {
  id              String   @id @default(cuid())
  patternKey      String
  targetDomain    String
  widgetType      String   @default("button")
  intention       String   @default("download")
  failedSelector  String
  repairedSelector String
  repairedLabel   String
  confidence      Float    @default(0.85)
  source          String   @default("llm")
  successCount    Int      @default(0)
  failureCount    Int      @default(0)
  autoAppliedCount Int     @default(0)
  status          String   @default("active")
  embeddingText   String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastUsedAt      DateTime?

  @@unique([patternKey])
  @@index([targetDomain])
  @@index([widgetType])
  @@index([intention])
  @@index([status])
}

// ============ Browser Use integration (optional adapter) ============

/// Tracks the Browser Use Cloud API key (self-provisioned via challenge-response).
/// Only one active key per deployment; stored encrypted-at-rest by the vault.
model BrowserUseKey {
  id              String   @id @default(cuid())
  apiKey          String
  email           String?
  name            String?
  claimUrl        String?
  status          String   @default("active")
  claimed         Boolean  @default(false)
  createdAt       DateTime @default(now())
  lastUsedAt      DateTime?

  @@index([status])
}

// ============ Multi-Tenant Registry (Option C — the network moat) ============

/// A tenant in the multi-tenant registry. Each tenant has their own connectors
/// and credentials but can subscribe to actions published by other tenants.
model Tenant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  plan            String   @default("free")  // free, pro, enterprise
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([status])
}

/// A published action in the shared registry. When a tenant publishes an
/// action, it becomes discoverable by other tenants who can subscribe to it.
/// The subscriber uses their own credentials but the publisher's action definition.
model PublishedAction {
  id              String   @id @default(cuid())
  actionId        String   // the source TypedAction id
  tenantId        String   // the publishing tenant
  name            String
  signature       String
  description     String   @default("")
  category        String   @default("other")
  version         String   @default("0.1.0")
  visibility      String   @default("public")  // public, private
  pricePerCall    Float    @default(0.0)  // in cents
  callCount       Int      @default(0)
  subscriberCount Int      @default(0)
  status          String   @default("active")  // active, deprecated
  publishedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([category])
  @@index([visibility])
  @@index([status])
}

/// A subscription: tenant B subscribes to tenant A's published action.
/// The subscriber uses their own credentials at runtime.
model ActionSubscription {
  id              String   @id @default(cuid())
  publishedActionId String
  subscriberTenantId String
  status          String   @default("active")  // active, cancelled
  createdAt       DateTime @default(now())
  cancelledAt     DateTime?

  @@unique([publishedActionId, subscriberTenantId])
  @@index([subscriberTenantId])
  @@index([publishedActionId])
}

/// Metered usage event for billing. Every call to a subscribed action
/// generates a UsageEvent.
model UsageEvent {
  id              String   @id @default(cuid())
  publishedActionId String
  subscriberTenantId String
  executionId     String?
  status          String   @default("success")  // success, failed
  costCents       Float    @default(0.0)
  createdAt       DateTime @default(now())

  @@index([publishedActionId])
  @@index([subscriberTenantId])
  @@index([createdAt])
}
